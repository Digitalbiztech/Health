generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  avatarUrl String? @map("avatar_url")
  role      Role    @default(USER)
  note      String? @db.Text

  // Supabase Auth reference — make non-nullable once all users are migrated
  supabaseId String? @unique @map("supabase_id")

  // Relations
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  uploads       Upload[]
  reports       Report[]        @relation("UserReports")
  chatSessions  ChatSession[]
  notifications Notification[]
  auditLogs     AuditLog[]      @relation("UserAuditLogs")
  reportExports ReportExport[]
  appointments  Appointment[]
  tasks         Task[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Patient {
  id          String   @id @default(uuid())
  email       String   @unique
  // Fixed: split into firstName/lastName to match User model convention
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  dateOfBirth DateTime @map("date_of_birth")
  gender      Gender
  note        String?  @db.Text

  // Supabase Auth reference — make non-nullable once all patients are migrated
  supabaseId String? @unique @map("supabase_id")

  // Relations
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  uploads        Upload[]
  reports        Report[]        @relation("PatientReports")
  chatSessions   ChatSession[]
  notifications  Notification[]
  auditLogs      AuditLog[]      @relation("PatientAuditLogs")
  reportExports  ReportExport[]
  appointments   Appointment[]
  tasks          Task[]
  documentChunks DocumentChunk[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([email])
  @@map("patients")
}

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique
  // Added: plan/tier for billing or feature flags per org
  plan OrganizationPlan @default(FREE)

  // Back-relations
  members       User[]
  patients      Patient[]
  uploads       Upload[]
  reports       Report[]
  chatSessions  ChatSession[]
  notifications Notification[]
  auditLogs     AuditLog[]
  reportExports ReportExport[]
  appointments  Appointment[]
  tasks         Task[]
  documentChunks DocumentChunk[]
  branding      OrganizationBranding?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organizations")
}

model OrganizationBranding {
  id               String  @id @default(uuid())
  
  // ── Identity ──
  brandName        String  @default("Auriem") @map("brand_name")
  tagline          String? // e.g., "AI-Powered Clinical Insights"
  poweredByText    String  @default("POWERED BY HUUMANIZE") @map("powered_by_text")
  
  // ── Logos (Supabase Storage URLs) ──
  logoMainUrl      String? @map("logo_main_url")       // Full horizontal logo
  logoIconUrl      String? @map("logo_icon_url")       // Square icon/favicon
  logoLetterformUrl String? @map("logo_letterform_url") // Compact lettermark
  faviconUrl       String? @map("favicon_url")
  
  // ── Color Palette (stored as HSL strings for CSS var injection) ──
  // Light mode
  colorPrimary          String @default("25 31% 75%") @map("color_primary")
  colorPrimaryForeground String @default("0 0% 100%") @map("color_primary_foreground")
  colorPrimaryText      String @default("25 20% 48%") @map("color_primary_text")
  colorPrimaryGlow      String @default("25 31% 75%") @map("color_primary_glow")
  colorAccent           String @default("30 11% 69%") @map("color_accent")
  
  // Dark mode overrides
  colorPrimaryDark          String @default("27 15% 49%") @map("color_primary_dark")
  colorPrimaryForegroundDark String @default("0 0% 100%") @map("color_primary_fg_dark")
  colorPrimaryTextDark      String @default("27 25% 65%") @map("color_primary_text_dark")
  colorAccentDark           String @default("30 11% 45%") @map("color_accent_dark")
  
  // ── PDF Theme ──
  pdfPrimaryColor   String @default("#0DA58E") @map("pdf_primary_color") // Base hex for palette derivation
  pdfAccentColor    String @default("#D4BDAD") @map("pdf_accent_color") // Hex for react-pdf
  pdfHeaderBg       String @default("#1f2937") @map("pdf_header_bg")
  pdfThemePreset    String @default("warm-gold") @map("pdf_theme_preset")
  
  // ── Feature Flags (plan-gated) ──
  showPoweredBy     Boolean @default(true) @map("show_powered_by")
  customFontsEnabled Boolean @default(false) @map("custom_fonts_enabled")
  fontFamily        String? @map("font_family") // Google Fonts family name
  
  // ── Relation ──
  organizationId String       @unique @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("organization_brandings")
}

// ============================================
// MEDICAL DATA MODELS
// ============================================

model Upload {
  id       String       @id @default(uuid())
  fileName String       @map("file_name")
  fileUrl  String       @map("file_url")
  // Fixed: enum instead of free string for type safety
  fileType FileType     @map("file_type")
  fileSize Int          @map("file_size")
  status   ProcessingStatus @default(PENDING)

  // Staff user who triggered the upload (null for patient self-uploads)
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  extraction Extraction?
  // Fixed: one-to-many so a report can be regenerated without hitting @unique
  reports    Report[]
  documentChunks DocumentChunk[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
  @@map("uploads")
}

model Extraction {
  id         String           @id @default(uuid())
  rawData    Json?            @map("raw_data")
  // Fixed: reuses ProcessingStatus enum (was ExtractionStatus — identical values)
  status     ProcessingStatus @default(PENDING)
  // Which extraction path produced the result (pymupdf, pdfplumber, mistral_ocr)
  source     String?
  // Confidence score 0–1 based on extraction method used
  confidence Float?
  // Version counter for re-processing support
  version    Int              @default(1)

  uploadId String @unique @map("upload_id")
  upload   Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  biomarkers     Biomarker[]
  documentChunks DocumentChunk[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("extractions")
}

model Biomarker {
  id             String          @id @default(uuid())
  canonicalName  String          @map("canonical_name")
  displayName    String          @map("display_name")
  // Decimal for medical precision (avoids floating-point rounding errors)
  value          Decimal         @db.Decimal(10, 4)
  unit           String
  referenceRange String?         @map("reference_range")
  status         BiomarkerStatus @default(NORMAL)
  category       String?
  referenceMin   Decimal?        @map("reference_min") @db.Decimal(10, 4)
  referenceMax   Decimal?        @map("reference_max") @db.Decimal(10, 4)
  confidence     Float?
  // Fixed: enum instead of free string
  source         BiomarkerSource? @default(EXTRACTED)

  extractionId String     @map("extraction_id")
  extraction   Extraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([extractionId, category])
  @@index([extractionId, status])
  @@index([status])
  @@map("biomarkers")
}

model Report {
  id      String       @id @default(uuid())
  title   String
  summary String?      @db.Text

  // Documented shape:
  // {
  //   schemaVersion: number,
  //   flags: { biomarkerId: string; severity: "LOW" | "HIGH" | "CRITICAL"; note: string }[],
  //   recommendations: string[],
  //   summaryPoints: string[]
  // }
  insights      Json?
  // Version counter alongside schemaVersion in JSON, for migration safety
  insightsSchemaVersion Int @default(1) @map("insights_schema_version")

  status ReportStatus @default(DRAFT)

  // Fixed: one Upload can have multiple Report versions
  uploadId String? @map("upload_id")
  upload   Upload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  // Added: version and isLatest for re-generation support
  version  Int     @default(1)
  isLatest Boolean @default(true) @map("is_latest")

  // Staff user who created the report (null for patient self-uploads)
  userId String? @map("user_id")
  user   User?   @relation("UserReports", fields: [userId], references: [id], onDelete: SetNull)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  patientId String?  @map("patient_id")
  patient   Patient? @relation("PatientReports", fields: [patientId], references: [id])

  // Moved PDF tracking to ReportExport — pdfUrl kept for quick last-export reference
  pdfUrl String? @map("pdf_url")

  exports ReportExport[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([patientId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
  // Efficiently find the latest version of a report per upload
  @@index([uploadId, isLatest])
  @@map("reports")
}

// ============================================
// PDF EXPORT TRACKING
// ============================================

model ReportExport {
  id      String  @id @default(uuid())
  pdfUrl  String  @map("pdf_url")
  // Signed URL expiry — null means permanent link
  expiresAt DateTime? @map("expires_at")

  reportId String @map("report_id")
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Polymorphic: either a staff user or a patient triggered the export
  generatedByUserId    String?  @map("generated_by_user_id")
  generatedByUser      User?    @relation(fields: [generatedByUserId], references: [id], onDelete: SetNull)
  generatedByPatientId String?  @map("generated_by_patient_id")
  generatedByPatient   Patient? @relation(fields: [generatedByPatientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([reportId])
  @@index([organizationId])
  @@map("report_exports")
}

// ============================================
// CHAT MODELS
// ============================================

model ChatSession {
  id    String  @id @default(uuid())
  title String?

  // Fixed: either a staff user OR a patient owns the session (not forced to staff)
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  patientId String?  @map("patient_id")
  patient   Patient? @relation(fields: [patientId], references: [id])

  messages ChatMessage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Note: enforce in app layer that exactly one of userId or patientId is non-null
  @@index([userId])
  @@index([patientId])
  @@index([organizationId])
  @@map("chat_sessions")
}

model ChatMessage {
  id      String      @id @default(uuid())
  role    MessageRole
  content String      @db.Text

  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id      String           @id @default(uuid())
  type    NotificationType
  message String
  read    Boolean          @default(false)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Polymorphic recipient — exactly one should be non-null (enforced at app layer)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId String?  @map("patient_id")
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Optional link back to the triggering entity
  entityType String? @map("entity_type") // e.g. "Report", "Upload"
  entityId   String? @map("entity_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([patientId, read])
  @@index([organizationId])
  @@map("notifications")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String    @id @default(uuid())
  action     AuditAction
  entityType String    @map("entity_type") // "Report", "Upload", "Biomarker", etc.
  entityId   String    @map("entity_id")

  // Polymorphic actor — staff user or patient
  actorUserId    String?  @map("actor_user_id")
  actorUser      User?    @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorPatientId String?  @map("actor_patient_id")
  actorPatient   Patient? @relation("PatientAuditLogs", fields: [actorPatientId], references: [id], onDelete: SetNull)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Extra context: IP, user agent, diff snapshot, etc.
  metadata  Json?
  ipAddress String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([actorPatientId, createdAt])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ============================================
// SCHEDULING & TASK MANAGEMENT
// ============================================

model Appointment {
  id        String            @id @default(uuid())
  title     String
  notes     String?           @db.Text
  startTime DateTime          @map("start_time")
  endTime   DateTime?         @map("end_time")
  status    AppointmentStatus @default(SCHEDULED)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Staff member the appointment is with (the doctor)
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, startTime])
  @@index([patientId])
  @@map("appointments")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Staff owner of the task
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Optional patient the task relates to
  patientId String?  @map("patient_id")
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@map("tasks")
}

// ============================================
// RAG VECTOR STORE
// ============================================
// These tables are read/written by the Python extraction service via pgvector.
// They MUST be modeled here (not just created via raw SQL) so `prisma migrate
// dev` doesn't treat them as drift and drop them. The `embedding` column uses a
// type Prisma can't express natively (`vector`), hence Unsupported(...). The
// HNSW vector indexes are created via raw SQL in the migration (Prisma can't
// emit them) and are intentionally not declared here.

model DocumentChunk {
  id             String        @id
  patientId      String        @map("patient_id")
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadId       String?       @map("upload_id")
  upload         Upload?       @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  extractionId   String?       @map("extraction_id")
  extraction     Extraction?   @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  chunkType  String  @map("chunk_type")
  chunkIndex Int     @default(0) @map("chunk_index")
  content    String
  metadata   Json?   @default("{}")
  embedding  Unsupported("vector(1536)")?
  reportType String? @map("report_type")
  reportDate DateTime? @map("report_date")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([patientId, chunkType])
  @@index([organizationId])
  @@index([reportType])
  @@index([reportDate])
  @@index([metadata], type: Gin)
  @@map("document_chunks")
}

model KnowledgeBaseChunk {
  id        String  @id
  topic     String
  content   String
  metadata  Json?   @default("{}")
  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([metadata], type: Gin)
  @@map("knowledge_base_chunks")
}

// ============================================
// ENUMS
// ============================================

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

// Staff roles only — patients are a separate model
enum Role {
  USER
  ADMIN
  DOCTOR
}

enum OrganizationPlan {
  FREE
  PRO
  ENTERPRISE
}

// Fixed: merged UploadStatus + ExtractionStatus — they had identical values
enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Fixed: enum instead of free string for upload file types
enum FileType {
  PDF
  IMAGE
  CSV
  OTHER
}

enum BiomarkerStatus {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// Fixed: enum instead of free string for biomarker data source
enum BiomarkerSource {
  EXTRACTED  // Pulled from uploaded file via OCR/parser
  MANUAL     // Entered by a doctor/user manually
  CALCULATED // Derived from other biomarker values
}

enum ReportStatus {
  DRAFT
  GENERATED
  REVIEWED
  PUBLISHED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum NotificationType {
  REPORT_READY
  REPORT_EXPORTED
  EXTRACTION_FAILED
  UPLOAD_FAILED
  UPLOAD_COMPLETED
  ACCOUNT_UPDATE
}

enum AuditAction {
  // Upload events
  UPLOAD_CREATED
  UPLOAD_DELETED
  UPLOAD_REPROCESSED
  // Report events
  REPORT_CREATED
  REPORT_UPDATED
  REPORT_PUBLISHED
  REPORT_EXPORTED
  REPORT_DELETED
  // Patient events
  PATIENT_CREATED
  PATIENT_UPDATED
  PATIENT_DELETED
  // Auth events
  USER_LOGIN
  USER_LOGOUT
  USER_ROLE_CHANGED
  // Chat events
  CHAT_SESSION_CREATED
  CHAT_SESSION_DELETED
}
